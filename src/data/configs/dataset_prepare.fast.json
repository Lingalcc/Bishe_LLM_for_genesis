{
  "dataset_prepare": {
    "generate": {
      "num_samples": 500,
      "seed": 42,
      "state_context_ratio": 0.5,
      "out_dir": "data_prepare",
      "alpaca_file": "genesis_franka_toolcall_alpaca.fast.json",
      "sharegpt_file": "genesis_franka_toolcall_sharegpt.fast.json",
      "stats_file": "genesis_franka_toolcall_stats.fast.json",
      "action_weights": {
        "move_ee": 10,
        "open_gripper": 6,
        "close_gripper": 6,
        "wait": 3,
        "step": 2,
        "get_state": 3,
        "reset_scene": 3,
        "set_qpos": 5,
        "set_dofs_position": 4,
        "control_dofs_position": 4,
        "control_dofs_velocity": 3,
        "control_dofs_force": 3,
        "seq_grasp_lift": 4,
        "seq_place": 4,
        "seq_reset_check": 2,
        "seq_joint_state": 2
      }
    },
    "augment": {
      "input_file": "data_prepare/genesis_franka_toolcall_alpaca.fast.json",
      "output_file": "data_prepare/genesis_franka_toolcall_alpaca.fast.aug.json",
      "stats_file": "data_prepare/genesis_franka_toolcall_augment_stats.fast.json",
      "output_sharegpt_file": "data_prepare/genesis_franka_toolcall_sharegpt.fast.aug.json",
      "seed": 42,
      "num_source": 120,
      "aug_per_sample": 1,
      "api_base": "https://api.openai.com/v1",
      "model": "gpt-5",
      "api_key": "",
      "api_key_env": "OPENAI_API_KEY",
      "temperature": 0.8,
      "max_tokens": 900,
      "timeout": 120,
      "max_retries": 5,
      "sleep_seconds": 0.2
    }
  }
}
